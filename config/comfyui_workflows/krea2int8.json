{
  "__doc__": "Template ComfyUI (format API) pour Krea 2 Turbo INT8 (fichier .safetensors int8mixed) SANS Triton : loader de diffusion standard (UNETLoader), encodeur Qwen3-VL en 'type: krea2' (CLIPLoader natif), VAE Qwen Image. Suppose que ComfyUI est recent (support INT8 natif). Si erreur 400 / mauvais rendu : montez le workflow dans l'UI ComfyUI, 'Save (API Format)', remettez les %JETONS%, remplacez ce fichier. Selon la version, 'type' du CLIPLoader ou 'weight_dtype' de l'UNETLoader peuvent devoir changer. Jetons: %UNET% %CLIP% %VAE% %POSITIVE% %NEGATIVE% %WIDTH% %HEIGHT% %BATCH% %SEED% %STEPS% %CFG% %SAMPLER% %SCHEDULER% %DENOISE% %LORA_NAME% %LORA_STRENGTH%.",
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "%UNET%", "weight_dtype": "default"},
    "_meta": {"title": "Diffusion Krea 2 Turbo INT8 (loader standard)"}
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {"clip_name": "%CLIP%", "type": "krea2"},
    "_meta": {"title": "Encodeur Qwen3-VL (type krea2)"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "%VAE%"},
    "_meta": {"title": "VAE Qwen Image"}
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["2", 0],
      "lora_name": "%LORA_NAME%",
      "strength_model": "%LORA_STRENGTH%",
      "strength_clip": "%LORA_STRENGTH%"
    },
    "_meta": {"title": "LoRA (ignore si LORA_NAME vide)"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "%POSITIVE%", "clip": ["10", 1]},
    "_meta": {"title": "Positive"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "%NEGATIVE%", "clip": ["10", 1]},
    "_meta": {"title": "Negative"}
  },
  "6": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "%WIDTH%", "height": "%HEIGHT%", "batch_size": "%BATCH%"},
    "_meta": {"title": "Latent vide"}
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": "%CFG%",
      "sampler_name": "%SAMPLER%",
      "scheduler": "%SCHEDULER%",
      "denoise": "%DENOISE%"
    },
    "_meta": {"title": "KSampler"}
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["7", 0], "vae": ["3", 0]},
    "_meta": {"title": "VAE Decode"}
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {"images": ["8", 0], "filename_prefix": "TSG_krea2int8"},
    "_meta": {"title": "Save"}
  }
}
