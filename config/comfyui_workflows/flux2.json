{
  "__doc__": "Template ComfyUI (format API) pour Flux.2 Klein GGUF. Les %JETONS% sont remplaces a la volee par le moteur (voir atelier/engine/comfyui.py). Si ComfyUI refuse ce graphe (400), reconstruisez un workflow qui marche dans l'UI ComfyUI, faites 'Save (API Format)', puis remettez les %JETONS% aux endroits indiques ci-dessous et remplacez ce fichier. Jetons: %UNET% %CLIP% %VAE% %POSITIVE% %NEGATIVE% %WIDTH% %HEIGHT% %BATCH% %SEED% %STEPS% %CFG% %SAMPLER% %SCHEDULER% %DENOISE% %LORA_NAME% %LORA_STRENGTH%.",
  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {"unet_name": "%UNET%"},
    "_meta": {"title": "Diffusion GGUF"}
  },
  "2": {
    "class_type": "CLIPLoaderGGUF",
    "inputs": {"clip_name": "%CLIP%", "type": "flux2"},
    "_meta": {"title": "Text encoder GGUF (ajuster 'type' si besoin)"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "%VAE%"},
    "_meta": {"title": "VAE"}
  },
  "10": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["2", 0],
      "lora_name": "%LORA_NAME%",
      "strength_model": "%LORA_STRENGTH%",
      "strength_clip": "%LORA_STRENGTH%"
    },
    "_meta": {"title": "LoRA (ignore si LORA_NAME vide)"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "%POSITIVE%", "clip": ["10", 1]},
    "_meta": {"title": "Positive"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "%NEGATIVE%", "clip": ["10", 1]},
    "_meta": {"title": "Negative"}
  },
  "6": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "%WIDTH%", "height": "%HEIGHT%", "batch_size": "%BATCH%"},
    "_meta": {"title": "Latent vide"}
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["6", 0],
      "seed": "%SEED%",
      "steps": "%STEPS%",
      "cfg": "%CFG%",
      "sampler_name": "%SAMPLER%",
      "scheduler": "%SCHEDULER%",
      "denoise": "%DENOISE%"
    },
    "_meta": {"title": "KSampler"}
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["7", 0], "vae": ["3", 0]},
    "_meta": {"title": "VAE Decode"}
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {"images": ["8", 0], "filename_prefix": "TSG_flux2"},
    "_meta": {"title": "Save"}
  }
}
